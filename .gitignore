benchmarks/*/src/
benchmarks/*/bin/
benchmarks/*/tests/*.test.js
benchmarks/*/test/
benchmarks/*/coverage/
benchmarks/*/node_modules/
benchmarks/*/package-lock.json

# Secrets
.env
.env.local

# Editors
.vscode/
.idea/
*.swp
