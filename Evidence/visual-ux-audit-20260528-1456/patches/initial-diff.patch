+            continue
+        name = rel.split(".valinor/handoff/", 1)[1]
+        src = stray_root / name
+        dst = bench_dir / rel
+        if src.exists() and src.is_file() and src.stat().st_size > 0 and (not dst.exists() or dst.stat().st_size == 0):
